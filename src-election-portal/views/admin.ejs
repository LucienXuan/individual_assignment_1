<!DOCTYPE html>
<html>
<head>
 <title>Admin Dashboard</title>
 <style>
  :root {
   --primary: #213d66;
   --secondary: #8c1d2c;
   --accent: #f4d78b;
   --surface-light: rgba(255,255,255,0.92);
   --muted: #566a8a;
  }
  body {
   margin: 0;
   font-family: Arial, sans-serif;
   background: linear-gradient(135deg, #213d66 0%, #8c1d2c 100%);
   color: #172033;
  }
  .topbar {
   background: rgba(255,255,255,0.92);
   border-bottom: 1px solid rgba(33, 61, 102, 0.12);
   padding: 18px 34px;
   display: flex;
   justify-content: space-between;
   align-items: center;
   box-shadow: 0 10px 30px rgba(20, 35, 65, 0.1);
  }
  .brand {
   display: flex;
   align-items: center;
   gap: 14px;
  }
  .brand-logo {
   display: flex;
   align-items: center;
   gap: 14px;
  }
  .brand-logo img {
   width: 70px;
  }
  .brand-logo img.secondary-logo {
   width: 56px;
  }
  .brand h1 {
   margin: 0;
   font-size: 24px;
   color: var(--primary);
  }
  .brand p {
   margin: 3px 0 0 0;
   color: var(--muted);
  }
  .logout {
   color: white;
   background: var(--secondary);
   padding: 10px 16px;
   border-radius: 10px;
   text-decoration: none;
   font-weight: bold;
  }
  .container {
   padding: 30px 34px;
   max-width: 1150px;
   margin: auto;
  }
  .welcome {
   background: rgba(255, 255, 255, 0.9);
   color: #172033;
   padding: 22px;
   border-radius: 18px;
   margin-bottom: 22px;
   border-left: 6px solid var(--secondary);
  }
  .welcome h2 {
   margin: 0 0 7px 0;
  }
  .welcome p {
   margin: 0;
  }
  .stats {
   display: grid;
   grid-template-columns: repeat(3, 1fr);
   gap: 18px;
   margin-bottom: 22px;
  }
  .stat-card {
   background: rgba(255,255,255,0.96);
   border: 1px solid rgba(33, 61, 102, 0.12);
   border-radius: 20px;
   padding: 22px;
   text-align: center;
   box-shadow: 0 12px 24px rgba(33, 61, 102, 0.06);
  }
  .number {
   font-size: 34px;
   font-weight: bold;
   color: var(--primary);
  }
  .label {
   margin-top: 7px;
   color: var(--muted);
   font-size: 12px;
   letter-spacing: 1px;
   text-transform: uppercase;
  }
  .section {
   background: rgba(255,255,255,0.94);
   border: 1px solid rgba(33, 61, 102, 0.1);
   border-radius: 20px;
   padding: 22px;
   margin-bottom: 22px;
   box-shadow: 0 12px 20px rgba(33, 61, 102, 0.05);
  }
  h3 {
   margin-top: 0;
   color: var(--primary);
  }
  .leader {
   display: flex;
   justify-content: space-between;
   gap: 14px;
   background: rgba(248, 250, 252, 0.95);
   padding: 18px;
   border-radius: 14px;
   margin-bottom: 10px;
   border-left: 4px solid var(--secondary);
  }
  .result-row {
   display: grid;
   grid-template-columns: 170px 1fr 70px;
   align-items: center;
   gap: 13px;
   padding: 12px 0;
   border-bottom: 1px solid rgba(33, 61, 102, 0.12);
  }
  .bar-bg {
   height: 13px;
   background: rgba(33, 61, 102, 0.08);
   border-radius: 50px;
   overflow: hidden;
  }
  .bar {
   height: 13px;
   width: var(--width, 0%);
   transition: width 0.35s ease;
  }
  .bar.blue {
   background: #213d66;
  }
  .bar.red {
   background: #d22335;
  }
  .bar.yellow {
   background: #f4d78b;
  }
  .vote-text {
   text-align: right;
   font-weight: bold;
   color: var(--primary);
  }
  .small {
   color: var(--muted);
   font-size: 13px;
  }
  @media (max-width: 800px) {
   .stats {
    grid-template-columns: 1fr;
   }
   .result-row {
    grid-template-columns: 1fr;
   }
  }
 </style>
</head>
<body>
 <div class="topbar">
  <div class="brand">
   <div class="brand-logo">
    <img src="/images/logo.png" alt="MILA University Logo">
    <img src="/images/SRC-logo-1.png" class="secondary-logo" alt="SRC Logo">
   </div>
   <div>
    <h1>Admin Dashboard</h1>
    <p>SRC Election Results</p>
   </div>
  </div>
  <a href="/logout" class="logout">Logout</a>
 </div>

 <div class="container">
  <div class="welcome">
   <h2>Welcome, <%= username %>!</h2>
   <p>You are viewing the live election results for all SRC positions.</p>
  </div>

  <div class="stats">
   <div class="stat-card">
    <div class="number"><%= data.totalStudents %></div>
    <div class="label">Total Students</div>
   </div>
   <div class="stat-card">
    <div class="number"><%= data.votesCast %></div>
    <div class="label">Students Voted</div>
   </div>
   <div class="stat-card">
    <div class="number"><%= data.participation %>%</div>
    <div class="label">Participation</div>
   </div>
  </div>

  <div class="section">
   <h3>Leading Candidates</h3>
   <% data.positions.forEach(position => { %>
    <div class="leader">
     <div>
      <strong><%= position.title %></strong><br>
      <span class="small"><%= position.leadingCandidate ? position.leadingCandidate.name : 'No candidate yet' %></span>
     </div>
     <div>
      <strong><%= position.leadingCandidate ? position.leadingCandidate.voteCount : 0 %></strong>
      <span class="small"> votes</span>
     </div>
    </div>
   <% }) %>
  </div>

  <% data.positions.forEach(position => { %>
   <div class="section">
    <h3><%= position.title %> Results</h3>
    <p class="small">Total votes for this position: <%= position.totalVotes %></p>

    <% position.candidates.forEach((candidate, idx) => { %>
     <% const barColors = ['blue', 'red', 'yellow']; %>
     <% const barColor = barColors[idx % barColors.length]; %>
     <div class="result-row">
      <div><strong><%= candidate.name %></strong><br><span class="small"><%= candidate.percent %>%</span></div>
      <div class="bar-bg"><div class="bar <%= barColor %>" style="--width: <%= candidate.percent %>%"></div></div>
      <div class="vote-text"><%= candidate.voteCount %></div>
     </div>
    <% }) %>
   </div>
  <% }) %>
 </div>
</body>
</html>
