<!DOCTYPE html>
<html>
<head>
 <title>Student Dashboard</title>
 <style>
  :root {
   --primary: #213d66;
   --secondary: #8c1d2c;
   --accent: #f4d78b;
   --surface: rgba(255,255,255,0.95);
   --muted: #556b8f;
  }
  body {
   margin: 0;
   font-family: Arial, sans-serif;
   background: linear-gradient(135deg, rgba(33,61,102,0.95), rgba(140,29,44,0.88));
   color: #172033;
  }
  .topbar {
   background: rgba(255,255,255,0.94);
   border-bottom: 1px solid rgba(33, 61, 102, 0.12);
   padding: 18px 34px;
   display: flex;
   justify-content: space-between;
   align-items: center;
   box-shadow: 0 10px 30px rgba(20, 35, 65, 0.08);
  }
  .brand {
   display: flex;
   align-items: center;
   gap: 14px;
  }
  .brand-logo {
   display: flex;
   align-items: center;
   gap: 14px;
  }
  .brand-logo img {
   width: 70px;
  }
  .brand-logo img.secondary-logo {
   width: 56px;
  }
  .brand h1 {
   margin: 0;
   font-size: 24px;
   color: var(--primary);
  }
  .brand p {
   margin: 3px 0 0 0;
   color: var(--muted);
  }
  .logout {
   color: white;
   background: var(--secondary);
   padding: 10px 16px;
   border-radius: 10px;
   text-decoration: none;
   font-weight: bold;
  }
  .container {
   padding: 30px 34px;
   max-width: 1150px;
   margin: auto;
  }
  .welcome {
   background: rgba(255,255,255,0.92);
   color: #172033;
   padding: 22px;
   border-radius: 18px;
   margin-bottom: 22px;
   border-left: 6px solid var(--secondary);
  }
  .welcome h2 {
   margin: 0 0 7px 0;
  }
  .welcome p {
   margin: 0;
  }
  .message {
   background: rgba(244, 215, 139, 0.18);
   color: #4a3c14;
   border-left: 4px solid var(--accent);
   padding: 13px;
   border-radius: 9px;
   margin-bottom: 22px;
  }
  .section {
   background: rgba(255,255,255,0.96);
   border: 1px solid rgba(33, 61, 102, 0.12);
   border-radius: 18px;
   padding: 22px;
   margin-bottom: 22px;
   box-shadow: 0 14px 26px rgba(33, 61, 102, 0.05);
  }
  h3 {
   margin-top: 0;
   color: var(--primary);
  }
  .cards {
   display: grid;
   grid-template-columns: repeat(3, 1fr);
   gap: 18px;
  }
  .candidate-card {
   border: 1px solid rgba(33, 61, 102, 0.12);
   border-radius: 18px;
   padding: 18px;
   background: var(--surface);
   transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .candidate-card:hover {
   transform: translateY(-3px);
   box-shadow: 0 20px 35px rgba(33, 61, 102, 0.12);
  }
  .candidate-card img {
   width: 76px;
   height: 76px;
   border-radius: 50%;
   display: block;
   margin-bottom: 12px;
   border: 2px solid var(--secondary);
    object-fit: cover;
    background: #f3f5f8;
  }
  .candidate-card h4 {
   margin: 0 0 4px 0;
   font-size: 17px;
   color: var(--primary);
  }
  .candidate-course {
   margin: 0 0 12px 0;
   color: var(--muted);
   font-size: 13px;
   line-height: 1.4;
  }
  .manifesto {
   color: #4a5368;
   line-height: 1.5;
   min-height: 95px;
  }
  button {
   width: 100%;
   background: var(--secondary);
   color: white;
   border: none;
   padding: 12px;
   border-radius: 10px;
   font-weight: bold;
   cursor: pointer;
  }
  .submitted {
   width: 100%;
   background: rgba(33, 61, 102, 0.08);
   color: var(--muted);
   border: none;
   padding: 12px;
   border-radius: 10px;
   font-weight: bold;
   text-align: center;
   box-sizing: border-box;
  }
  .small {
   color: var(--muted);
   font-size: 13px;
  }
  @media (max-width: 900px) {
   .cards {
    grid-template-columns: 1fr;
   }
  }
 </style>
</head>
<body>
 <div class="topbar">
  <div class="brand">
   <div class="brand-logo">
    <img src="/images/logo.png" alt="MILA University Logo">
    <img src="/images/SRC-logo-1.png" class="secondary-logo" alt="SRC Logo">
   </div>
   <div>
    <h1>Student Dashboard</h1>
    <p>SRC Election Voting</p>
   </div>
  </div>
  <a href="/logout" class="logout">Logout</a>
 </div>

 <div class="container">
  <div class="welcome">
   <h2>Welcome, <%= voter ? voter.name : username %>!</h2>
   <p>Please view the candidates and submit your vote. You can vote once for each position only.</p>
  </div>

  <% if (message) { %>
   <div class="message"><%= message %></div>
  <% } %>

  <% data.positions.forEach(position => { %>
   <div class="section">
    <h3><%= position.title %></h3>
    <% if (votedPositionIds.indexOf(position.id) === -1) { %>
     <p class="small">Please choose one candidate for this position.</p>
    <% } else { %>
     <p class="small">Vote submitted for this position.</p>
    <% } %>

    <div class="cards">
     <% position.candidates.forEach(candidate => { %>
      <div class="candidate-card">
       <img src="<%= candidate.photo %>" alt="Candidate profile image">
       <h4><%= candidate.name %></h4>
       <p class="candidate-course"><%= candidate.course || 'Bachelor of Computer Engineering, Year 3, Sem 6' %></p>
       <p class="manifesto"><%= candidate.manifesto %></p>

       <% if (votedPositionIds.indexOf(position.id) === -1) { %>
        <form action="/vote" method="POST">
         <input type="hidden" name="positionId" value="<%= position.id %>">
         <input type="hidden" name="candidateId" value="<%= candidate.id %>">
         <button type="submit" onclick="return confirm('Confirm your vote for <%= candidate.name %>?');">Vote</button>
        </form>
       <% } else { %>
        <div class="submitted">Vote submitted</div>
       <% } %>
      </div>
     <% }) %>
    </div>
   </div>
  <% }) %>
 </div>
</body>
</html>
